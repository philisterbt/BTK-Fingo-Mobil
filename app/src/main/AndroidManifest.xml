<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher_fingo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_fingo"
        android:supportsRtl="true"
        android:theme="@style/Theme.Fingo">

        <!-- Giriş ekranı — LAUNCHER -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Kayıt ekranı -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Piyasa (Ana Ekran) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- Cüzdanım -->
        <activity
            android:name=".WalletActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- Fin-Agent -->
        <activity
            android:name=".FinAgentActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- Akademi -->
        <activity
            android:name=".AcademyActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- Sanal İşlem Detay Sayfası -->
        <activity
            android:name=".TradeDetailActivity"
            android:exported="false"
            android:launchMode="singleTop" />

    </application>

</manifest>