<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TOP BAR -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="20dp"
                android:paddingTop="52dp" android:paddingBottom="4dp">
                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_circle" android:src="@drawable/ic_person"
                    android:padding="8dp" android:scaleType="centerInside"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:text="FinGo" android:textSize="22sp" android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- Page Title -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Akademi" android:textColor="@color/text_primary"
                android:textSize="30sp" android:textStyle="bold"
                android:paddingStart="20dp" android:paddingTop="20dp" android:paddingBottom="6dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Seviyeni yükselt ve finansal becerilerini geliştir."
                android:textColor="@color/text_secondary" android:textSize="14sp"
                android:paddingStart="20dp" android:paddingBottom="20dp"
                android:lineSpacingMultiplier="1.4"/>

            <!-- AI DICTIONARY CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍  AI Finans Sözlüğü (ELI5)"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card_bordered"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etSearchTerm"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Terim yazın (örn: Hedging, Kaldıraç)"
                        android:textColorHint="@color/text_secondary"
                        android:textColor="@color/text_primary"
                        android:background="@null"
                        android:textSize="14sp"
                        android:inputType="text"/>

                    <ImageView
                        android:id="@+id/btnSearchTerm"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/accent_green"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Explanation Result Container -->
                <LinearLayout
                    android:id="@+id/layoutExplanationResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvExplainedTerm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_green"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvTermExplanation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>
            </LinearLayout>



            <!-- CHART CHALLENGE CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp">

                <!-- Progress Header -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView android:id="@+id/tvChallengeSymbolBadge"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip"
                        android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                        android:text="BTC" android:textColor="@color/accent_green"
                        android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="  GEÇMİŞ GRAFİK ARENASI"
                        android:textColor="@color/text_secondary" android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Challenge Title -->
                <TextView android:id="@+id/tvChallengeTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Yükleniyor..."
                    android:textColor="@color/text_primary" android:textSize="16sp"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>

                <!-- Challenge Description -->
                <TextView android:id="@+id/tvChallengeDescription"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AI grafik verisi ve formasyon analizi indiriliyor..."
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.3" android:layout_marginBottom="16dp"/>

                <!-- Dynamic Line Chart Container! -->
                <com.example.fingo.LineChartView
                    android:id="@+id/chartView"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="@color/bg_card_elevated"
                    android:layout_marginBottom="20dp"/>

                <!-- Prediction Options Container -->
                <LinearLayout
                    android:id="@+id/layoutPredictionOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="10dp">

                    <!-- Guess UP -->
                    <LinearLayout android:id="@+id/btnPredictUp"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_option" android:padding="12dp"
                        android:orientation="horizontal" android:gravity="center"
                        android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🟢  Yükselir" android:textColor="@color/accent_green"
                            android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Guess DOWN -->
                    <LinearLayout android:id="@+id/btnPredictDown"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="6dp"
                        android:background="@drawable/bg_option" android:padding="12dp"
                        android:orientation="horizontal" android:gravity="center"
                        android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔴  Düşer" android:textColor="@color/error_red"
                            android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Explanation Result Container -->
                <LinearLayout
                    android:id="@+id/layoutChallengeResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvChallengeResultTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_green"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvChallengeResultText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.3"/>
                </LinearLayout>

                <!-- Continue Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextChallenge"
                    style="@style/FinDu.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sonraki Grafik Arenası"/>
            </LinearLayout>

            <!-- LEARNING RESOURCES CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📚" android:textSize="18sp" android:layout_marginEnd="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Finansal Başucu Kaynakları" android:textColor="@color/text_primary"
                        android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Resource 1 -->
                <LinearLayout android:id="@+id/btnResourceSPK"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/bg_option" android:padding="12dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏛️" android:textSize="20sp" android:layout_marginEnd="10dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Finansal Okuryazarlık Portalı" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Devlet destekli resmi eğitim modülleri ve rehberler."
                            android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="➔" android:textColor="@color/accent_green" android:textSize="16sp"/>
                </LinearLayout>

                <!-- Resource 2 -->
                <LinearLayout android:id="@+id/btnResourceBIST"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/bg_option" android:padding="12dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📈" android:textSize="20sp" android:layout_marginEnd="10dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Borsa İstanbul Yatırımcı Rehberi" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Borsada hisse senedi alım satım kuralları ve terimleri."
                            android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="➔" android:textColor="@color/accent_green" android:textSize="16sp"/>
                </LinearLayout>

                <!-- Resource 3 -->
                <LinearLayout android:id="@+id/btnResourceKhan"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/bg_option" android:padding="12dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp" android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎓" android:textSize="20sp" android:layout_marginEnd="10dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Khan Academy Finans Kursu" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Faiz, hisse senedi ve enflasyon konularında video dersler."
                            android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="➔" android:textColor="@color/accent_green" android:textSize="16sp"/>
                </LinearLayout>

                <!-- Resource 4 -->
                <LinearLayout android:id="@+id/btnResourceBook"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:background="@drawable/bg_option" android:padding="12dp"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:clickable="true" android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📘" android:textSize="20sp" android:layout_marginEnd="10dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Başucu Kitabı: Babil'in En Zengin Adamı" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tarihin en popüler bütçe yönetimi ve tasarruf kitabı."
                            android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="➔" android:textColor="@color/accent_green" android:textSize="16sp"/>
                </LinearLayout>
            </LinearLayout>



        </LinearLayout>
    </ScrollView>

    <include layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
