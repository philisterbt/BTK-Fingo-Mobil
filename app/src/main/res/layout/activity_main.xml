<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle"
                android:src="@drawable/ic_person"
                android:padding="8dp"
                android:scaleType="centerInside"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="FinGo"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

        </LinearLayout>

        <!-- SEARCH BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_search"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                android:alpha="0.5"/>
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:hint="Varlık, hisse veya kripto ara..."
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:background="@null"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"/>
        </LinearLayout>

        <!-- CATEGORY CHIPS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/chipHepsi"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hepsi" android:textColor="#0D1117" android:textSize="13sp"
                    android:textStyle="bold" android:background="@drawable/bg_chip_active"
                    android:paddingStart="18dp" android:paddingEnd="18dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/chipKripto"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Kripto" android:textColor="@color/text_secondary"
                    android:textSize="13sp" android:background="@drawable/bg_chip"
                    android:paddingStart="18dp" android:paddingEnd="18dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/chipHisseler"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hisseler" android:textColor="@color/text_secondary"
                    android:textSize="13sp" android:background="@drawable/bg_chip"
                    android:paddingStart="18dp" android:paddingEnd="18dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/chipPopuler"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Popüler" android:textColor="@color/text_secondary"
                    android:textSize="13sp" android:background="@drawable/bg_chip"
                    android:paddingStart="18dp" android:paddingEnd="18dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- FEATURED BTC CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:gravity="center_vertical" android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="44dp" android:layout_height="44dp"
                    android:background="@drawable/bg_circle"
                    android:gravity="center" android:layout_marginEnd="12dp">
                    <TextView android:id="@+id/tvFeaturedIcon"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₿" android:textColor="@color/accent_green"
                        android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:id="@+id/tvFeaturedSymbol"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BTC/USDT" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                    <TextView android:id="@+id/tvFeaturedName"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Bitcoin" android:textColor="@color/text_primary"
                        android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>
                <TextView android:id="@+id/tvBtcPrice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Yükleniyor..."
                    android:textColor="@color/text_primary"
                    android:textSize="22sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Real Chart -->
            <com.github.mikephil.charting.charts.CandleStickChart
                android:id="@+id/btcChart"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="16dp" />

            <!-- Percentage buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:id="@+id/btn25" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:gravity="center" android:text="25%"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:background="@drawable/bg_chip" android:layout_marginEnd="6dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn50" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:gravity="center" android:text="50%"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:background="@drawable/bg_chip" android:layout_marginEnd="6dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn75" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:gravity="center" android:text="75%"
                    android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:background="@drawable/bg_chip" android:layout_marginEnd="6dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/btn100" android:layout_width="0dp" android:layout_height="36dp"
                    android:layout_weight="1" android:gravity="center" android:text="100%"
                    android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_chip" android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Buy / Sell -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSanalAl"
                    style="@style/FinDu.Button.Primary"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🛒  SANAL AL" android:layout_marginEnd="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSanalSat"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="🏷️  SANAL SAT"
                    android:backgroundTint="#2DFF5252" android:textColor="@color/error_red"
                    android:textStyle="bold" android:textSize="14sp"
                    app:cornerRadius="14dp" android:paddingTop="16dp" android:paddingBottom="16dp"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </LinearLayout>

        <!-- List Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingStart="20dp" android:paddingEnd="20dp"
            android:gravity="center_vertical" android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Piyasa Listesi"
                android:textColor="@color/text_primary" android:textSize="17sp" android:textStyle="bold"/>
            <ProgressBar android:id="@+id/progressBar"
                android:layout_width="24dp" android:layout_height="24dp"
                android:indeterminateTint="@color/accent_green"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Ticker RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTickers"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="80dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <include layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>